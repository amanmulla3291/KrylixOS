# kernel-krylix.config — KrylixOS Linux Hardened Kernel Configuration
# Base: Linux 6.12.y LTS — defconfig + security hardening + AWS drivers
# Do not edit manually — use build-kernel.sh which enforces critical options via scripts/config

# ============================================================
# CORE ARCHITECTURE
# ============================================================
CONFIG_X86_64=y
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=256
CONFIG_PREEMPT=y
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y

# ============================================================
# SECURITY — Non-negotiable hardening
# ============================================================
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=y
# CONFIG_SECURITY_SELINUX_BOOTPARAM is not set
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_AVC_STATS=y
CONFIG_LOCKDOWN_LSM=y
CONFIG_LOCKDOWN_LSM_EARLY=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA256=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_HARDENED_USERCOPY_FALLBACK=n
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_KASLR=y
CONFIG_PAGE_TABLE_ISOLATION=y
CONFIG_RETPOLINE=y
CONFIG_GCC_PLUGIN_STRUCTLEAK=y
CONFIG_GCC_PLUGIN_STRUCTLEAK_BYREF_ALL=y
CONFIG_GCC_PLUGIN_RANDSTRUCT=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_ZERO_CALL_USED_REGS=y

# Lockdown: protect against even root compromising kernel integrity
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y

# ============================================================
# BPF — Required for Falco eBPF
# ============================================================
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_CGROUP_BPF=y
CONFIG_BPF_EVENTS=y
CONFIG_PERF_EVENTS=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_TRACEPOINTS=y
CONFIG_TRACING=y
CONFIG_FTRACE=y
CONFIG_DEBUG_FS=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_ARCH_WANT_DEFAULT_BPF_JIT=y

# ============================================================
# CGROUPS — cgroupv2
# ============================================================
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_RDMA=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_CGROUP_BPF=y
CONFIG_CPUSETS=y
CONFIG_PROC_PID_CPUSET=y
# Force cgroupv2 (unified hierarchy)
CONFIG_CGROUP_V2=y

# ============================================================
# FILESYSTEMS
# ============================================================
CONFIG_XFS_FS=y
CONFIG_XFS_QUOTA=y
CONFIG_XFS_POSIX_ACL=y
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_OVERLAY_FS=y
# CONFIG_BTRFS_FS is not set
# CONFIG_NFS_FS is not set  (not needed for target profiles)

# ============================================================
# CRYPTO — LUKS2 requirements
# ============================================================
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_BLAKE2B=y
CONFIG_CRYPTO_ARGON2=y
CONFIG_DM_CRYPT=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=y

# ============================================================
# NETWORKING — Minimal, hardened
# ============================================================
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_HASH=y
CONFIG_NET_SCH_INGRESS=y      # Required for Suricata IPS AF_PACKET
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_TCP_CONG_CUBIC=y
# CONFIG_IPX is not set
# CONFIG_DECNET is not set
# CONFIG_ATALK is not set

# ============================================================
# VIRTUALIZATION / CLOUD — AWS ENA + NVMe
# ============================================================
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_RNG=y            # VM profile: use virtio-rng for entropy seeding
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_ENA_ETH=y               # AWS Elastic Network Adapter
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_FABRICS=n
CONFIG_SCSI_VIRTIO=y
CONFIG_XEN=n                   # Not targeting Xen
CONFIG_KVM_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_PARAVIRT_CLOCK=y

# TPM2 — Bare metal profile LUKS2 unsealing
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_CRB=y
CONFIG_TRUSTED_KEYS=y

# ============================================================
# IOMMU — bare metal security (force-on in bare-metal.sh)
# ============================================================
CONFIG_IOMMU_SUPPORT=y
CONFIG_INTEL_IOMMU=y
CONFIG_AMD_IOMMU=y
CONFIG_IOMMU_DEFAULT_PASSTHROUGH=n
CONFIG_VFIO=n

# ============================================================
# STORAGE — Minimal (NVMe + SATA, no tape)
# ============================================================
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_SATA_SIL=y
# CONFIG_SCSI_TAPE is not set
# CONFIG_SCSI_LOWLEVEL is not set (beyond standard)

# ============================================================
# USB — Minimal (storage + HID only, no printer)
# ============================================================
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
# CONFIG_USB_PRINTER is not set
# CONFIG_USB_NET_DRIVERS is not set

# ============================================================
# DISABLED — Attack surface reduction
# ============================================================
# CONFIG_BT is not set
# CONFIG_SOUND is not set
# CONFIG_SND is not set
# CONFIG_SND_INTEL_NHLT is not set
# CONFIG_HAMRADIO is not set
# CONFIG_STAGING is not set
# CONFIG_FB is not set
# CONFIG_DRM is not set              (headless server — no GPU/display)
# CONFIG_VGA_CONSOLE is not set
# CONFIG_MOUSE_PS2 is not set
# CONFIG_INPUT_JOYSTICK is not set
# CONFIG_INPUT_TOUCHSCREEN is not set
# CONFIG_VIDEO_DEV is not set
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_INFINIBAND is not set
# CONFIG_WIMAX is not set
# CONFIG_IEEE802154 is not set
# CONFIG_FIREWIRE is not set
# CONFIG_PCCARD is not set
# CONFIG_RAPIDIO is not set
# CONFIG_CDROM_PKTCDVD is not set
# CONFIG_MFD_SUPPORT is not set

# ============================================================
# DEBUGGING — Disabled in production build
# ============================================================
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_KASAN is not set
# CONFIG_UBSAN is not set
# CONFIG_KCSAN is not set
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_LOG_BUF_SHIFT=18
